# ═══════════════════════════════════════════════════════════════════════════════
# BetaLab v2.0 — Configuration d'Environnement
# Copier ce fichier en .env et adapter les valeurs
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# BASE DE DONNÉES
# ─────────────────────────────────────────────────────────────────────────────
DB_USER=luc
DB_PASSWORD=luc123
DB_HOST=localhost
DB_NAME=db_lab

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTIFICATION ADMIN (Nouvelles variables)
# ─────────────────────────────────────────────────────────────────────────────
# Créé automatiquement à la première exécution si n'existe pas
ADMIN_USERNAME=admin
ADMIN_PASSWORD=AdminPassword123@Secure
ADMIN_EMAIL=admin@betalab.local

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (SMTP)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_app
SMTP_FROM=BetaLab
FRONTEND_URL=http://localhost:30000

# ─────────────────────────────────────────────────────────────────────────────
# SÉCURITÉ (Nouvelles options)
# ─────────────────────────────────────────────────────────────────────────────
CSRF_ENABLED=true
CSRF_TOKEN_EXPIRY=86400

# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=INFO

# CREATE DATABASE
# mysql -u root -e "CREATE DATABASE db_lab;"
